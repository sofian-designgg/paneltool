# Discord - Required for website → ticket creation
# Same bot token as your Sayuri Shop Discord bot
DISCORD_BOT_TOKEN=your_bot_token

# Your Discord server (guild) ID
DISCORD_GUILD_ID=your_guild_id

# Ticket category ID (where new tickets are created)
# Same category used by +ticketsetup
DISCORD_TICKET_CATEGORY_ID=your_category_id

# Support role IDs (comma-separated) - optional
# These roles can see the ticket channels
DISCORD_SUPPORT_ROLE_IDS=role_id_1,role_id_2
