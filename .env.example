# Discord - Ticket creation
DISCORD_BOT_TOKEN=your_bot_token
DISCORD_GUILD_ID=your_guild_id
DISCORD_TICKET_CATEGORY_ID=your_category_id
DISCORD_SUPPORT_ROLE_IDS=role_id_1,role_id_2

# Discord OAuth - Connect before buy (customer sees ticket)
# Create app at https://discord.com/developers/applications
# Add redirect: https://paneltool.vercel.app/api/auth/callback
DISCORD_CLIENT_ID=your_client_id
DISCORD_CLIENT_SECRET=your_client_secret

# For OAuth redirect (production)
NEXT_PUBLIC_APP_URL=https://paneltool.vercel.app
